#!/usr/bin/env bash
set -e

# Bắt lỗi bằng EXIT thay vì ERR để tương thích với Husky
finish() {
  if [ $? -ne 0 ]; then
    echo "❌ pre-commit checks failed!"
  fi
}
trap finish EXIT

# Frontend
echo "Checking Frontend..."
cd frontend
npm run lint

# Backend
echo "Checking Backend..."
cd ../backend

# SỬA LỖI TẠI ĐÂY: Dùng dấu chấm (.) thay vì chữ source
. venv/bin/activate

# Format with black
if command -v python3 &> /dev/null; then
  python3 -m black .
else
  python -m black .
fi

echo "✅ Backend formatted with Black!"

# Lint with flake8
if command -v python3 &> /dev/null; then
  python3 -m flake8 app/
else
  python -m flake8 app/
fi