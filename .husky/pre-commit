#!/usr/bin/env bash
set -e

# Trap errors
trap 'echo "❌ pre-commit checks failed!"; exit 1' ERR

# Frontend
cd frontend
npm run lint

# Backend
cd ../backend

source venv/bin/activate

# Format with black
if command -v python3 &> /dev/null; then
  python3 -m black .
else
  python -m black .
fi

echo "✅ Backend formatted with Black!"

# Lint with flake8
if command -v python3 &> /dev/null; then
  python3 -m flake8 app/
else
  python -m flake8 app/
fi